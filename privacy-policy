*{margin:0;padding:0;box-sizing:border-box}
:root{--green:#1A4731;--green-dk:#122E21;--gold:#C9A96E;--parch:#F4F1EC;--parch-d:#EAE6DC;--ink:#111111;--muted:#767670;--white:#FFFFFF}
body{font-family:'Outfit',sans-serif;background:var(--parch);color:var(--ink);line-height:1.7}
.site-header{background:var(--green-dk);border-bottom:3px solid var(--gold);padding:18px 40px;display:flex;align-items:center;justify-content:space-between}
.brand{display:flex;align-items:center;gap:14px;text-decoration:none}
.brand-name{font-family:'Cormorant Garamond',serif;font-size:20px;color:var(--white);font-weight:600;letter-spacing:2px}
.brand-sub{font-size:10px;color:var(--gold);letter-spacing:2px;text-transform:uppercase}
.back-link{font-size:13px;color:var(--gold);text-decoration:none;letter-spacing:1px;opacity:0.8}
.back-link:hover{opacity:1}
.hero{background:var(--green);padding:60px 40px;text-align:center;border-bottom:3px solid var(--gold)}
.hero-eyebrow{font-size:11px;font-weight:600;color:var(--gold);letter-spacing:3px;text-transform:uppercase;margin-bottom:16px}
.hero-title{font-family:'Cormorant Garamond',serif;font-size:48px;font-weight:600;color:var(--white);margin-bottom:12px}
.hero-date{font-size:13px;color:rgba(255,255,255,0.5)}
.content{max-width:800px;margin:0 auto;padding:60px 40px}
.section{margin-bottom:48px}
.section-title{font-family:'Cormorant Garamond',serif;font-size:26px;font-weight:600;color:var(--green);margin-bottom:16px;padding-bottom:10px;border-bottom:1px solid var(--gold)}
.section p{font-size:15px;color:var(--ink);line-height:1.8;margin-bottom:14px}
.section ul{margin:12px 0 14px 20px}
.section ul li{font-size:15px;color:var(--ink);line-height:1.8;margin-bottom:6px}
.section a{color:var(--green);text-decoration:none;border-bottom:1px solid var(--gold)}
.highlight-box{background:var(--parch-d);border-left:3px solid var(--gold);padding:20px 24px;margin:20px 0}
.highlight-box p{margin-bottom:0;font-size:14px}
.site-footer{background:var(--green-dk);border-top:3px solid var(--gold);padding:32px 40px;text-align:center}
.footer-brand{font-family:'Cormorant Garamond',serif;font-size:18px;color:var(--white);letter-spacing:2px;margin-bottom:6px}
.footer-tag{font-size:11px;color:var(--gold);letter-spacing:2px;text-transform:uppercase;margin-bottom:16px}
.footer-links{display:flex;gap:24px;justify-content:center;margin-bottom:16px}
.footer-links a{font-size:13px;color:rgba(255,255,255,0.5);text-decoration:none}
.footer-links a:hover{color:var(--gold)}
.footer-copy{font-size:12px;color:rgba(255,255,255,0.3)}
@media(max-width:768px){.site-header{padding:16px 20px}.hero{padding:40px 20px}.hero-title{font-size:34px}.content{padding:40px 20px}}
